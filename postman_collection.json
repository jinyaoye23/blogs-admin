            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"更新后的标题\",\n  \"content\": \"更新后的内容\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/articles/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "articles", "1"]
            }
          }
        },
        {
          "name": "删除文章",
          "request": {
